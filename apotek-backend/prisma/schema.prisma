generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================
// TABEL PENGGUNA
// ==================
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(KASIR)
  isActive     Boolean  @default(true)
  phone        String?
  avatarUrl    String?
  shift        StafShift @default(OFF)
  outletId     String?
  outlet       Outlet?   @relation(fields: [outletId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions  Transaction[]
  orders        Order[]
  ocrScans      OcrScan[]
  addresses     Address[]
  prescriptions Prescription[]
  reports       UserReport[]
  shifts        CashShift[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  APOTEKER
  KASIR
  PASIEN
}

// ==================
// TABEL OBAT
// ==================
model Drug {
  id              String      @id @default(uuid())
  name            String
  genericName     String?
  brandName       String?
  activeIngredient String?
  category        DrugCategory @default(BEBAS)
  type            DrugType     @default(GENERIK)
  unit            String       @default("tablet")
  minStock        Int          @default(10)
  sellPrice       Float
  buyPrice        Float
  rxcui           String?
  bpomNumber      String?
  description     String?
  imageUrl        String?
  rxnormName           String?
  rxnormIngredients    String?
  fdaIndications       String?
  fdaSideEffects       String?
  fdaDosage            String?
  fdaWarnings          String?
  fdaContraindications String?
  lastApiSync          DateTime?
  requiresPrescription Boolean  @default(false)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  batches          DrugBatch[]
  transactionItems TransactionItem[]
  orderItems       OrderItem[]

  outletId         String?
  outlet           Outlet?      @relation(fields: [outletId], references: [id])
}

enum DrugCategory {
  BEBAS
  BEBAS_TERBATAS
  KERAS
  NARKOTIKA
  PSIKOTROPIKA
}

enum DrugType {
  GENERIK
  PATEN
  BPJS
}

// ==================
// TABEL STOK / BATCH
// ==================
model DrugBatch {
  id           String    @id @default(uuid())
  drugId       String
  drug         Drug      @relation(fields: [drugId], references: [id])
  batchNumber  String
  stock        Int
  buyPrice     Float
  expiredDate  DateTime
  receivedDate DateTime  @default(now())
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  outletId     String?
  outlet       Outlet?   @relation(fields: [outletId], references: [id])
  createdAt    DateTime  @default(now())

  transactionItems TransactionItem[]
}

// ==================
// TABEL SUPPLIER
// ==================
model Supplier {
  id             String          @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  createdAt      DateTime        @default(now())

  batches        DrugBatch[]
  purchaseOrders PurchaseOrder[]
}

// ==================
// TABEL TRANSAKSI (KASIR)
// ==================
model Transaction {
  id            String        @id @default(uuid())
  cashierId     String
  cashier       User          @relation(fields: [cashierId], references: [id])
  subtotal      Float         @default(0)
  discountType  String        @default("NOMINAL")
  discountValue Float         @default(0)
  discountAmount Float        @default(0)
  totalAmount   Float
  paymentMethod PaymentMethod @default(CASH)
  amountPaid    Float
  change        Float         @default(0)
  status        TxStatus      @default(COMPLETED)
  notes         String?
  shiftId       String?
  shift         CashShift?    @relation(fields: [shiftId], references: [id])
  outletId      String?
  outlet        Outlet?       @relation(fields: [outletId], references: [id])
  createdAt     DateTime      @default(now())

  items TransactionItem[]
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  DEBIT
  CREDIT
}

enum TxStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  drugId        String
  drug          Drug        @relation(fields: [drugId], references: [id])
  batchId       String
  batch         DrugBatch   @relation(fields: [batchId], references: [id])
  quantity      Int
  sellPrice     Float
  subtotal      Float
}

// ==================
// TABEL ORDER (PASIEN)
// ==================
model Order {
  id             String         @id @default(uuid())
  patientId      String
  patient        User           @relation(fields: [patientId], references: [id])
  totalAmount    Float
  shippingFee    Float          @default(0)
  paymentMethod  String         @default("CASH")
  status         OrderStatus    @default(PENDING)
  orderCode      String         @unique
  paymentProof   String?
  notes          String?
  deliveryMethod DeliveryMethod @default(PICKUP)
  addressId      String?
  address        Address?       @relation(fields: [addressId], references: [id])
  prescriptionId String?
  prescription   Prescription?  @relation(fields: [prescriptionId], references: [id])
  outletId       String?
  outlet         Outlet?        @relation(fields: [outletId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items OrderItem[]
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id])
  drugId   String
  drug     Drug   @relation(fields: [drugId], references: [id])
  quantity Int
  price    Float
  subtotal Float
}

// ==================
// TABEL OCR SCAN
// ==================
model OcrScan {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  imageUrl   String?
  rawText    String?
  parsedDrugs Json?
  createdAt  DateTime @default(now())
}

// ==================
// TABEL ALAMAT
// ==================
model Address {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  label         String   @default("Rumah")
  recipientName String
  phone         String
  street        String
  city          String
  province      String
  postalCode    String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]
}

// ==================
// TABEL RESEP DOKTER
// ==================
model Prescription {
  id              String             @id @default(uuid())
  patientId       String
  patient         User               @relation(fields: [patientId], references: [id])
  imageUrl        String
  notes           String?
  status          PrescriptionStatus @default(PENDING)
  verifiedBy      String?
  verifiedAt      DateTime?
  prescribedDrugs Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  orders Order[]
}

enum PrescriptionStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ==================
// TABEL LAPORAN PENGGUNA
// ==================
model UserReport {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  title      String
  category   ReportCategory @default(GENERAL)
  message    String
  status     ReportStatus   @default(OPEN)
  adminReply String?
  repliedBy  String?
  repliedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

enum ReportCategory {
  GENERAL
  ORDER
  DRUG_QUALITY
  SERVICE
  PAYMENT
  OTHER
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ==================
// TABEL PURCHASE ORDER
// ==================
model PurchaseOrder {
  id          String        @id @default(uuid())
  supplierId  String
  supplier    Supplier      @relation(fields: [supplierId], references: [id])
  orderDate   DateTime      @default(now())
  status      POStatus      @default(PENDING)
  totalAmount Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       POItem[]
}

model POItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  drugId          String
  drugName        String
  quantity        Int
  price           Float
  subtotal        Float
}

enum POStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

// ==================
// SHIFT KASIR & STAF
// ==================
model CashShift {
  id                String       @id @default(uuid())
  cashierId         String
  cashier           User         @relation(fields: [cashierId], references: [id])
  startTime         DateTime     @default(now())
  endTime           DateTime?
  startBalance      Float
  endBalance        Float?
  expectedBalance   Float?
  difference        Float?
  totalSales        Float?
  totalTransactions Int?
  status            ShiftStatus  @default(OPEN)
  notes             String?
  outletId          String?
  outlet            Outlet?      @relation(fields: [outletId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  transactions      Transaction[]
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum StafShift {
  PAGI
  SIANG
  MALAM
  OFF
}

// ==================
// TABEL OUTLET / CABANG APOTEK
// ==================
model Outlet {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  latitude  Float?
  longitude Float?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  batches      DrugBatch[]
  transactions Transaction[]
  orders       Order[]
  shifts       CashShift[]
  drugs        Drug[]
}

// ==================
// DATA REFERENSI EKSTERNAL & LOG
// ==================
model DrugReference {
  id              String    @id @default(uuid())
  name            String    @unique
  genericName     String?
  activeIngredient String?
  description     String?
  indications     String?
  sideEffects     String?
  dosage          String?
  warnings        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EpidemiologyTrend {
  id              String   @id @default(uuid())
  indicatorCode   String
  indicatorName   String
  spatialValue    String   // Misal: "IDN" untuk Indonesia
  year            Int
  value           Float
  diseaseCategory String   // Misal: "MALARIA", "TB", "DENGUE"
  lastSync        DateTime @default(now())
}

model SyncLog {
  id                 String    @id @default(uuid())
  category           String    // Misal: "DRUGS" atau "EPIDEMIOLOGY"
  status             String    // "SUCCESS" atau "FAILED"
  scrapedItemsCount  Int       @default(0)
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  triggeredBy        String    // Nama pengguna / "SYSTEM" (Jika Scheduler)
  errorMessage       String?
}